{
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/email/monday-bump",
      "schedule": "5 11 * * 1"
    },
    {
      "path": "/api/cron/check-inbox",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/sync-hubspot",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/drip-sequence",
      "schedule": "0 13 * * *"
    }
  ]
}
