generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 Int       @id @default(autoincrement())
  rank               Int
  name               String    @unique
  parent_brand       String?
  vertical           String
  signal_type        String?
  why_now            String?
  primo_angle        String?
  best_intro_path    String?
  source             String?
  source_url_1       String?
  source_url_2       String?
  icp_fit            Int       @default(0)
  modex_signal       Int       @default(0)
  primo_story_fit    Int       @default(0)
  warm_intro         Int       @default(0)
  strategic_value    Int       @default(0)
  meeting_ease       Int       @default(0)
  priority_score     Int       @default(0)
  priority_band      String    @default("D")
  tier               String    @default("Tier 3")
  owner              String    @default("Casey")
  research_status    String    @default("Not started")
  outreach_status    String    @default("Not started")
  meeting_status     String    @default("No meeting")
  pipeline_stage     String    @default("targeted")
  current_motion     String?
  next_action        String?
  due_date           DateTime?
  notes              String?
  hubspot_company_id String?   @unique
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  personas              Persona[]
  outreach_waves        OutreachWave[]
  meeting_brief         MeetingBrief?
  audit_route           AuditRoute?
  qr_asset              QrAsset?
  activities            Activity[]
  meetings              Meeting[]
  mobile_captures       MobileCapture[]
  microsite_engagements MicrositeEngagement[]
  generationJobs        GenerationJob[]
  operator_outcomes     OperatorOutcome[]
  signal_content_links  SignalContentLink[]
  message_evolutions    MessageEvolutionRegistry[]
  canonical_company_links CanonicalAccountLink[]
  canonical_conflicts   CanonicalConflict[]
  contact_candidates    AccountContactCandidate[]

  @@map("accounts")
}

model Persona {
  id                       Int       @id @default(autoincrement())
  persona_id               String    @unique
  account_name             String
  priority                 String
  name                     String
  first_name               String?
  last_name                String?
  normalized_name          String?
  title                    String?
  normalized_title         String?
  persona_lane             String?
  role_in_deal             String?
  intro_route              String?
  function                 String?
  seniority                String?
  why_this_persona         String?
  linkedin_url             String?
  attendance_signal        String?
  intro_path               String?
  persona_status           String    @default("To find")
  next_step                String?
  notes                    String?
  account_score            Int       @default(0)
  email                    String?
  email_valid              Boolean   @default(true)
  email_status             String    @default("unverified")
  email_confidence         Int       @default(0)
  company_domain           String?
  phone                    String?
  phone_status             String    @default("unknown")
  linkedin_confidence      Int       @default(0)
  source_type              String?
  source_url               String?
  source_evidence          Json?
  quality_score            Int       @default(0)
  quality_band             String    @default("D")
  is_contact_ready         Boolean   @default(false)
  do_not_contact           Boolean   @default(false)
  contact_standard_version String    @default("2026-03-28")
  hubspot_contact_id       String?   @unique
  last_enriched_at         DateTime?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  account    Account            @relation(fields: [account_name], references: [name])
  enrichment ContactEnrichment?
  canonical_contact CanonicalContact?
  canonical_conflicts CanonicalConflict[]

  @@unique([account_name, email])
  @@index([account_name])
  @@index([email])
  @@index([quality_score])
  @@map("personas")
}

enum EnrichmentSource {
  hubspot
  apollo
  derived
  manual
}

model ContactEnrichment {
  id                    Int       @id @default(autoincrement())
  persona_id            Int       @unique
  hubspot_contact_id    String?
  apollo_person_id      String?
  enrichment_confidence Float?
  last_enriched_at      DateTime?
  merge_version         String    @default("v1")
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  persona Persona                  @relation(fields: [persona_id], references: [id], onDelete: Cascade)
  fields  ContactEnrichmentField[]

  @@index([hubspot_contact_id])
  @@index([apollo_person_id])
  @@index([last_enriched_at])
  @@map("contact_enrichments")
}

model ContactEnrichmentField {
  id                    Int              @id @default(autoincrement())
  contact_enrichment_id Int
  field_name            String
  field_value           String?
  source                EnrichmentSource
  source_timestamp      DateTime?
  confidence            Float?
  last_writer           String?
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt

  contact_enrichment ContactEnrichment @relation(fields: [contact_enrichment_id], references: [id], onDelete: Cascade)

  @@unique([contact_enrichment_id, field_name])
  @@index([field_name])
  @@index([source, source_timestamp])
  @@map("contact_enrichment_fields")
}

model AccountContactCandidate {
  id                    Int      @id @default(autoincrement())
  account_name          String
  candidate_key         String
  full_name             String
  normalized_name       String?
  title                 String?
  email                 String?
  email_valid           Boolean  @default(false)
  email_confidence      Int      @default(0)
  company_domain        String?
  linkedin_url          String?
  source                String?
  source_action         String   @default("company_contacts")
  source_provider       String?
  source_contact_id     String?
  source_payload        Json?
  confidence_score      Int      @default(0)
  quality_score         Int      @default(0)
  readiness_score       Int      @default(0)
  readiness_tier        String   @default("low")
  readiness_details     Json?
  recommended           Boolean  @default(false)
  recommendation_reason String?
  state                 String   @default("staged")
  promoted_persona_id   Int?
  replaced_persona_id   Int?
  deferred_reason       String?
  last_seen_at          DateTime @default(now())
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  account Account @relation(fields: [account_name], references: [name], onDelete: Cascade)

  @@unique([account_name, candidate_key])
  @@index([account_name, state])
  @@index([readiness_score])
  @@index([recommended])
  @@map("account_contact_candidates")
}

model Campaign {
  id                   Int       @id @default(autoincrement())
  name                 String
  slug                 String    @unique
  status               String    @default("active")
  campaign_type        String    @default("trade_show")
  start_date           DateTime?
  end_date             DateTime?
  target_account_count Int       @default(0)
  messaging_angle      String?
  key_dates            Json?
  owner                String    @default("Casey")
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  outreach_waves      OutreachWave[]
  activities          Activity[]
  generated_content   GeneratedContent[]
  email_logs          EmailLog[]
  generationJobs      GenerationJob[]
  send_job_recipients SendJobRecipient[]
  operator_outcomes   OperatorOutcome[]
  signal_content_links SignalContentLink[]
  message_evolutions   MessageEvolutionRegistry[]
  generation_contract  CampaignGenerationContract?
  playbook_blocks      PlaybookBlock[]

  @@map("campaigns")
}

model OutreachWave {
  id                     Int       @id @default(autoincrement())
  wave                   String
  wave_order             Int
  account_name           String
  campaign_id            Int?
  rank                   Int?
  tier                   String?
  priority_score         Int?
  channel_mix            String?
  primary_objective      String?
  use_warm_intro         Boolean   @default(false)
  use_primo_asset        Boolean   @default(false)
  primary_persona_lane   String?
  secondary_persona_lane String?
  start_date             DateTime?
  followup_1             DateTime?
  followup_2             DateTime?
  escalation_trigger     String?
  meeting_goal           String?
  owner                  String    @default("Jake")
  status                 String    @default("Not started")
  notes                  String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  account  Account   @relation(fields: [account_name], references: [name])
  campaign Campaign? @relation(fields: [campaign_id], references: [id])

  @@index([account_name])
  @@index([campaign_id])
  @@map("outreach_waves")
}

model MeetingBrief {
  id                  Int      @id @default(autoincrement())
  account_name        String   @unique
  vertical            String?
  modex_signal        String?
  why_this_account    String?
  why_now             String?
  likely_pain         String?
  primo_relevance     String?
  best_outcome        String?
  suggested_attendees String?
  prep_assets         String?
  open_questions      String?
  source_url_1        String?
  source_url_2        String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  account Account @relation(fields: [account_name], references: [name])

  @@map("meeting_briefs")
}

model AuditRoute {
  id            Int      @id @default(autoincrement())
  rank          Int?
  account_name  String   @unique
  audit_url     String
  suggested_ask String?
  fast_ask      String?
  proof_asset   String?
  warm_route    String?
  graphic_file  String?
  owner         String   @default("Jake / Casey")
  status        String   @default("Open")
  last_touch    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  account Account @relation(fields: [account_name], references: [name])

  @@map("audit_routes")
}

model QrAsset {
  id            Int      @id @default(autoincrement())
  account_name  String   @unique
  audit_url     String
  suggested_use String?
  proof_asset   String?
  graphic_file  String?
  notes         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  account Account @relation(fields: [account_name], references: [name])

  @@map("qr_assets")
}

model Activity {
  id            Int       @id @default(autoincrement())
  activity_date DateTime?
  account_name  String
  campaign_id   Int?
  persona       String?
  activity_type String
  owner         String?
  outcome       String?
  next_step     String?
  next_step_due DateTime?
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  account  Account   @relation(fields: [account_name], references: [name])
  campaign Campaign? @relation(fields: [campaign_id], references: [id])

  @@index([account_name])
  @@index([campaign_id])
  @@map("activities")
}

model MicrositeEngagement {
  id               String   @id @default(cuid())
  session_id       String
  account_slug     String
  account_name     String
  person_slug      String?
  person_name      String?
  variant_slug     String?
  path             String
  sections_viewed  String[] @default([])
  cta_ids          String[] @default([])
  variant_history  String[] @default([])
  last_cta_id      String?
  scroll_depth_pct Int      @default(0)
  duration_seconds Int      @default(0)
  source_domain    String?
  metadata         Json?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  account Account @relation(fields: [account_name], references: [name])

  @@unique([session_id, path])
  @@index([account_name])
  @@index([account_slug])
  @@index([person_slug])
  @@map("microsite_engagements")
}

model Meeting {
  id              Int       @id @default(autoincrement())
  meeting_id_str  String?
  account_name    String
  persona         String?
  meeting_status  String    @default("No meeting")
  meeting_date    DateTime?
  meeting_time    String?
  location        String?
  primo_involved  Boolean   @default(false)
  jake_confirmed  Boolean   @default(false)
  objective       String?
  owner           String?
  hubspot_deal_id String?
  post_next_step  String?
  notes           String?
  account_score   Int?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  account Account @relation(fields: [account_name], references: [name])

  @@index([account_name])
  @@index([hubspot_deal_id])
  @@map("meetings")
}

model MobileCapture {
  id                Int       @id @default(autoincrement())
  captured_at       DateTime  @default(now())
  account_name      String
  persona_name      String?
  title             String?
  channel           String?
  intent            String?
  need_trigger      String?
  requested_asset   String?
  need_primo        Boolean   @default(false)
  owner             String?
  due_date          DateTime?
  next_step         String?
  outcome           String?
  notes             String?
  interest          Int       @default(0)
  urgency           Int       @default(0)
  influence         Int       @default(0)
  fit               Int       @default(0)
  heat_score        Int       @default(0)
  band              String?
  followup_template String?
  followup_status   String?
  synced_at         DateTime?
  audit_url         String?
  source_proof      String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  account Account @relation(fields: [account_name], references: [name])

  @@index([account_name])
  @@index([synced_at])
  @@map("mobile_captures")
}

model SearchString {
  id                Int      @id @default(autoincrement())
  account           String
  wave              String?
  priority          String?
  function          String?
  target_title      String?
  named_seed        String?
  sales_nav_query   String?
  linkedin_query    String?
  google_xray_query String?
  keywords          String?
  source_signal     String?
  owner             String?
  status            String   @default("Ready")
  notes             String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("search_strings")
}

model ActionableIntel {
  id              Int      @id @default(autoincrement())
  account         String
  intel_type      String
  why_it_matters  String?
  how_to_find     String?
  owner           String?
  status          String   @default("Open")
  field_to_update String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("actionable_intel")
}

model ListsConfig {
  id    Int    @id @default(autoincrement())
  key   String
  value String

  @@unique([key, value])
  @@map("lists_config")
}

model GeneratedContent {
  id                  Int       @id @default(autoincrement())
  account_name        String
  campaign_id         Int?
  persona_name        String?
  content_type        String // email | dm | call_script | meeting_prep | infographic
  tone                String? // formal | conversational | provocative
  length              String? // short | medium | long
  provider_used       String?
  ai_error            String?
  version             Int       @default(1)
  is_published        Boolean   @default(false)
  published_at        DateTime?
  external_send_count Int       @default(0)
  version_metadata    Json?
  content             String
  created_at          DateTime  @default(now())

  campaign            Campaign?          @relation(fields: [campaign_id], references: [id])
  send_job_recipients SendJobRecipient[]
  operator_outcomes   OperatorOutcome[]
  signal_content_links SignalContentLink[]
  message_evolution_current MessageEvolutionRegistry[] @relation("MessageEvolutionCurrentVersion")
  message_evolution_previous MessageEvolutionRegistry[] @relation("MessageEvolutionPreviousVersion")
  checklist_state     ContentChecklistState?
  playbook_blocks     PlaybookBlock[]

  @@index([account_name, content_type])
  @@index([campaign_id])
  @@index([account_name, content_type, version])
  @@map("generated_content")
}

model GenerationJob {
  id            Int       @id @default(autoincrement())
  account_name  String
  campaign_id   Int?
  persona_name  String?
  content_type  String // one_pager | email | dm | call_script | meeting_prep
  status        String    @default("pending")
  provider_used String?
  error_message String?
  retry_count   Int       @default(0)
  batch_id      String?
  scheduled_at  DateTime?
  started_at    DateTime?
  completed_at  DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  account  Account   @relation(fields: [account_name], references: [name])
  campaign Campaign? @relation(fields: [campaign_id], references: [id])

  @@index([status, updated_at])
  @@index([account_name, campaign_id])
  @@map("generation_jobs")
}

model OperatorOutcome {
  id                   String    @id @default(cuid())
  account_name         String
  campaign_id          Int?
  generated_content_id Int?
  outcome_label        String
  source_kind          String
  source_id            String
  notes                String?
  created_by           String?
  created_at           DateTime  @default(now())

  account           Account           @relation(fields: [account_name], references: [name], onDelete: Cascade)
  campaign          Campaign?         @relation(fields: [campaign_id], references: [id])
  generated_content GeneratedContent? @relation(fields: [generated_content_id], references: [id])

  @@unique([source_kind, source_id, outcome_label])
  @@index([account_name, created_at])
  @@index([campaign_id, created_at])
  @@index([generated_content_id, created_at])
  @@index([outcome_label, created_at])
  @@map("operator_outcomes")
}

model SignalContentLink {
  id                   String    @id @default(cuid())
  account_name         String
  campaign_id          Int?
  generated_content_id Int?
  source_kind          String
  source_id            String
  signal_kind          String
  signal_context       String?
  outcome_label        String?
  email_log_id         Int?
  send_job_recipient_id Int?
  created_at           DateTime  @default(now())

  account           Account           @relation(fields: [account_name], references: [name], onDelete: Cascade)
  campaign          Campaign?         @relation(fields: [campaign_id], references: [id])
  generated_content GeneratedContent? @relation(fields: [generated_content_id], references: [id])
  message_evolutions MessageEvolutionRegistry[]

  @@unique([source_kind, source_id])
  @@index([account_name, created_at])
  @@index([generated_content_id, created_at])
  @@map("signal_content_links")
}

model MessageEvolutionRegistry {
  id                           String    @id @default(cuid())
  account_name                 String
  campaign_id                  Int?
  signal_content_link_id       String?
  previous_generated_content_id Int?
  generated_content_id         Int
  status                       String    @default("proposed")
  owner                        String    @default("Casey")
  sla_due_at                   DateTime?
  rationale                    String
  evidence_snapshot            Json?
  rollback_link                String?
  reviewed_by                  String?
  reviewed_at                  DateTime?
  deployed_at                  DateTime?
  created_at                   DateTime  @default(now())
  updated_at                   DateTime  @updatedAt

  account               Account            @relation(fields: [account_name], references: [name], onDelete: Cascade)
  campaign              Campaign?          @relation(fields: [campaign_id], references: [id])
  signal_content_link   SignalContentLink? @relation(fields: [signal_content_link_id], references: [id])
  generated_content     GeneratedContent   @relation("MessageEvolutionCurrentVersion", fields: [generated_content_id], references: [id])
  previous_generated_content GeneratedContent? @relation("MessageEvolutionPreviousVersion", fields: [previous_generated_content_id], references: [id])

  @@index([status, sla_due_at])
  @@index([account_name, created_at])
  @@index([generated_content_id, created_at])
  @@map("message_evolution_registry")
}

model EmailLog {
  id                    Int       @id @default(autoincrement())
  account_name          String
  campaign_id           Int?
  persona_name          String?
  to_email              String
  subject               String
  body_html             String
  status                String    @default("sent") // sent | delivered | opened | clicked | bounced
  provider_message_id   String?
  generated_content_id  Int?
  hubspot_engagement_id String?
  thread_id             String?
  reply_count           Int       @default(0)
  opened_at             DateTime?
  clicked_at            DateTime?
  delivered_at          DateTime?
  open_count            Int       @default(0)
  bounce_type           String? // hard | soft
  metadata              Json?
  sent_at               DateTime  @default(now())
  created_at            DateTime  @default(now())

  campaign            Campaign?          @relation(fields: [campaign_id], references: [id])
  send_job_recipients SendJobRecipient[]

  @@index([account_name])
  @@index([campaign_id])
  @@index([status])
  @@index([provider_message_id])
  @@index([thread_id])
  @@map("email_logs")
}

model SendJob {
  id               Int       @id @default(autoincrement())
  status           String    @default("pending") // pending | processing | completed | failed | partial | cancelled
  requested_by     String?
  experiment_id    String?
  primary_metric   String?
  send_strategy    Json?
  total_recipients Int       @default(0)
  sent_count       Int       @default(0)
  failed_count     Int       @default(0)
  skipped_count    Int       @default(0)
  error_message    String?
  started_at       DateTime?
  completed_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  recipients SendJobRecipient[]
  experiment Experiment?       @relation(fields: [experiment_id], references: [id])
  approval_requests SendApprovalRequest[]

  @@index([status, created_at])
  @@index([experiment_id])
  @@map("send_jobs")
}

model ContentChecklistState {
  id                   String   @id @default(cuid())
  generated_content_id Int      @unique
  campaign_type        String?
  completed_item_ids   String[] @default([])
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  generated_content GeneratedContent @relation(fields: [generated_content_id], references: [id], onDelete: Cascade)

  @@index([campaign_type, updated_at])
  @@map("content_checklist_states")
}

model SendJobRecipient {
  id                    Int       @id @default(autoincrement())
  send_job_id           Int
  generated_content_id  Int
  campaign_id           Int?
  experiment_id         String?
  variant_id            String?
  variant_key           String?
  account_name          String
  persona_name          String?
  to_email              String
  subject               String
  body_html             String
  status                String    @default("pending") // pending | sending | sent | failed | skipped
  error_message         String?
  provider_message_id   String?
  hubspot_engagement_id String?
  email_log_id          Int?
  idempotency_key       String    @unique
  attempted_at          DateTime?
  sent_at               DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  send_job          SendJob          @relation(fields: [send_job_id], references: [id], onDelete: Cascade)
  generated_content GeneratedContent @relation(fields: [generated_content_id], references: [id])
  campaign          Campaign?        @relation(fields: [campaign_id], references: [id])
  email_log         EmailLog?        @relation(fields: [email_log_id], references: [id])
  experiment        Experiment?      @relation(fields: [experiment_id], references: [id])
  variant           ExperimentVariant? @relation(fields: [variant_id], references: [id])

  @@unique([send_job_id, generated_content_id, to_email])
  @@index([send_job_id, status])
  @@index([status, created_at])
  @@index([generated_content_id])
  @@index([campaign_id])
  @@index([experiment_id, variant_key, status])
  @@map("send_job_recipients")
}

model PlaybookBlock {
  id                   String   @id @default(cuid())
  title                String
  body                 String
  block_type           String
  account_name         String?
  campaign_id          Int?
  generated_content_id Int?
  tags                 String[] @default([])
  industry             String?
  persona              String?
  stage                String?
  motion               String?
  usage_count          Int      @default(0)
  success_rate         Float    @default(0)
  confidence_score     Float    @default(0)
  created_by           String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  campaign          Campaign?         @relation(fields: [campaign_id], references: [id])
  generated_content GeneratedContent? @relation(fields: [generated_content_id], references: [id])

  @@index([block_type, created_at])
  @@index([industry, persona, stage, motion])
  @@map("playbook_blocks")
}

model SendApprovalRequest {
  id            String   @id @default(cuid())
  send_job_id   Int?
  channel       String
  account_name  String?
  risk_score    Int
  risk_reasons  String[] @default([])
  status        String   @default("pending")
  requested_by  String?
  approved_by   String?
  comment       String?
  sla_due_at    DateTime?
  resolved_at   DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  send_job SendJob? @relation(fields: [send_job_id], references: [id], onDelete: SetNull)

  @@index([status, sla_due_at])
  @@index([account_name, created_at])
  @@map("send_approval_requests")
}

model CampaignGenerationContract {
  id                    String   @id @default(cuid())
  campaign_id           Int      @unique
  objective             String
  persona_hypothesis    String
  offer                 String
  proof                 String
  cta                   String
  metric                String
  quality_score         Int      @default(0)
  is_complete           Boolean  @default(false)
  created_by            String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@index([is_complete, quality_score])
  @@map("campaign_generation_contracts")
}

model Experiment {
  id             String   @id @default(cuid())
  name           String
  primary_metric String
  split          Json
  status         String   @default("active")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  variants      ExperimentVariant[]
  send_jobs     SendJob[]
  recipients    SendJobRecipient[]

  @@index([created_at])
  @@map("experiments")
}

model ExperimentVariant {
  id             String   @id @default(cuid())
  experiment_id  String
  variant_key    String
  subject        String
  opening        String?
  cta            String?
  split_percent  Int
  is_control     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  experiment     Experiment        @relation(fields: [experiment_id], references: [id], onDelete: Cascade)
  recipients     SendJobRecipient[]

  @@unique([experiment_id, variant_key])
  @@index([experiment_id])
  @@map("experiment_variants")
}

model UnsubscribedEmail {
  id              String   @id @default(cuid())
  email           String   @unique
  unsubscribed_at DateTime @default(now())
  reason          String?
  email_log_id    Int?

  @@index([email])
  @@map("unsubscribed_emails")
}

model WebhookEvent {
  id           String   @id
  type         String
  processed_at DateTime @default(now())

  @@index([id])
  @@index([processed_at])
  @@map("webhook_events")
}

model Notification {
  id            Int      @id @default(autoincrement())
  type          String // reply | open | click | bounce | meeting_booked | hot_engagement
  account_name  String?
  persona_email String?
  subject       String?
  preview       String?
  source_id     String? // e.g. email_log id, webhook event id
  read          Boolean  @default(false)
  created_at    DateTime @default(now())

  @@index([read])
  @@index([type])
  @@index([created_at])
  @@map("notifications")
}

model CanonicalCompany {
  id                 String   @id
  company_key        String   @unique
  source             String
  hubspot_company_id String?
  domain             String?
  primary_account_name String?
  status             String   @default("resolved")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  account_links CanonicalAccountLink[]
  contacts      CanonicalContact[]
  conflicts     CanonicalConflict[]

  @@index([hubspot_company_id])
  @@index([domain])
  @@map("canonical_companies")
}

model CanonicalAccountLink {
  id                   Int      @id @default(autoincrement())
  account_name         String   @unique
  canonical_company_id String
  status               String   @default("resolved")
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  account Account @relation(fields: [account_name], references: [name], onDelete: Cascade)
  canonical_company CanonicalCompany @relation(fields: [canonical_company_id], references: [id], onDelete: Cascade)

  @@index([canonical_company_id])
  @@map("canonical_account_links")
}

model CanonicalContact {
  id                   String   @id
  canonical_key        String?
  persona_id           Int      @unique
  canonical_company_id String?
  email                String?
  hubspot_contact_id   String?
  status               String   @default("resolved")
  source               String?
  block_reason         String?
  conflict_codes       Json?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  persona Persona @relation(fields: [persona_id], references: [id], onDelete: Cascade)
  canonical_company CanonicalCompany? @relation(fields: [canonical_company_id], references: [id], onDelete: SetNull)
  conflicts CanonicalConflict[]

  @@index([canonical_company_id])
  @@index([canonical_key])
  @@index([email])
  @@index([hubspot_contact_id])
  @@map("canonical_contacts")
}

model CanonicalConflict {
  id                   Int      @id @default(autoincrement())
  code                 String
  status               String   @default("open")
  reason               String?
  persona_id           Int?
  account_name         String?
  canonical_contact_id String?
  canonical_company_id String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  persona Persona? @relation(fields: [persona_id], references: [id], onDelete: SetNull)
  account Account? @relation(fields: [account_name], references: [name], onDelete: SetNull)
  canonical_contact CanonicalContact? @relation(fields: [canonical_contact_id], references: [id], onDelete: SetNull)
  canonical_company CanonicalCompany? @relation(fields: [canonical_company_id], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([persona_id])
  @@index([account_name])
  @@index([canonical_company_id])
  @@index([canonical_contact_id])
  @@map("canonical_conflicts")
}

model SystemConfig {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt

  @@map("system_config")
}
